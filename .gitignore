.DS_Store
node_modules/
browse/dist/
backups/
evals/outputs/
*.bun-build
config.local.md

# Per-worktree gbrain source pin (kubectl-style context). Machine-specific
# source ID written by /sync-gbrain; each developer generates their own.
.gbrain-source

# Seed content (law/, defaults/) is tracked; user-specific content is not.
# /setup copies seed templates to the user's vault on first run.
knowledge/practice/
knowledge/matters/
knowledge/memory/

# Python bytecode (release.sh commits with git add -A)
__pycache__/
*.pyc

# Isolated dev worktrees (git worktree add / EnterWorktree)
.worktrees/
.claude/worktrees/
