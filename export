#!/usr/bin/env bash
set -e

COUNSEL_DIR="$(cd "$(dirname "$0")" && pwd)"
VERSION="$(cat "$COUNSEL_DIR/VERSION" 2>/dev/null || echo "unknown")"
OUTPUT_DIR="${1:-$(dirname "$COUNSEL_DIR")}"
OUTPUT_FILE="$OUTPUT_DIR/counsel-os-plugin.zip"
PLUGIN_NAME="$(basename "$COUNSEL_DIR")"

echo "Exporting Counsel OS v$VERSION as Cowork plugin..."

# ── Build zip matching v0.7.13's working recipe ──────────────────────────
# Wrap everything in `counsel-os/` and exclude only the things v0.7.13 did:
# build artifacts, VCS metadata, knowledge/ (large; users seed via /setup),
# and macOS noise. Past iterations added more exclusions trying to "fix"
# Cowork upload failures — none of those attempts worked, and each one
# diverged us further from the empirically-known-good shape. Keeping it
# minimal until there's evidence a specific exclusion actually helps.

cd "$(dirname "$COUNSEL_DIR")"
rm -f "$OUTPUT_FILE"

zip -r "$OUTPUT_FILE" "$PLUGIN_NAME/" \
  -x "$PLUGIN_NAME/.git/*" \
  -x "$PLUGIN_NAME/.git" \
  -x "$PLUGIN_NAME/node_modules/*" \
  -x "$PLUGIN_NAME/browse/*" \
  -x "$PLUGIN_NAME/backups/*" \
  -x "$PLUGIN_NAME/knowledge/matters/*" \
  -x "$PLUGIN_NAME/knowledge/practice/*" \
  -x "$PLUGIN_NAME/knowledge/memory/*" \
  -x "$PLUGIN_NAME/docs/*" \
  -x "$PLUGIN_NAME/bun.lock" \
  -x "$PLUGIN_NAME/.DS_Store" \
  -x "$PLUGIN_NAME/**/.DS_Store" \
  -x "$PLUGIN_NAME/*.bun-build" \
  -x "$PLUGIN_NAME/CLAUDE.md" \
  -x "$PLUGIN_NAME/.claude/*" \
  -x "$PLUGIN_NAME/config.local.md" \
  > /dev/null

SIZE="$(du -h "$OUTPUT_FILE" | cut -f1 | tr -d ' ')"

echo ""
echo "Exported: $OUTPUT_FILE ($SIZE)"
echo ""
echo "Includes: .claude-plugin/, primitives/, skills/, knowledge/law/,"
echo "          knowledge/practice-seed/, templates/, config.md, etc."
echo "Excludes: .git/, node_modules/, browse/, backups/, docs/, bun.lock,"
echo "          *.bun-build, .DS_Store, CLAUDE.md, .claude/, config.local.md,"
echo "          knowledge/{matters,practice,memory}/ (user state, gitignored)"
echo ""
echo "To install in Cowork:"
echo "  1. Open Claude Desktop → Cowork → Customize → Browse plugins"
echo "  2. Remove the old Counsel OS plugin (if installed)"
echo "  3. Upload $OUTPUT_FILE"
echo "  4. Run /counsel-os:setup to seed content into your vault"
