#!/usr/bin/env bash
set -e

COUNSEL_DIR="$(cd "$(dirname "$0")" && pwd)"
VERSION="$(cat "$COUNSEL_DIR/VERSION" 2>/dev/null || echo "unknown")"
OUTPUT_DIR="${1:-$(dirname "$COUNSEL_DIR")}"
OUTPUT_FILE="$OUTPUT_DIR/counsel-os-plugin.zip"
PLUGIN_NAME="$(basename "$COUNSEL_DIR")"

echo "Exporting Counsel OS v$VERSION as Cowork plugin..."

# ── Build zip with files at the archive ROOT (no wrapper directory) ──────
# Cowork expects .claude-plugin/plugin.json at the zip root.
# This matches Anthropic's official cowork-plugin-customizer recipe:
#   https://github.com/anthropics/knowledge-work-plugins
#
# Excludes:
#   - User-specific config and local dev settings (config.local.md, .claude/, .mcp.json)
#   - VCS metadata (.git, .gitignore, .source-repo, .content-versions.json)
#   - Build artifacts (node_modules, bun.lock, *.bun-build, browse/)
#   - Backups, docs (not needed at runtime)
#   - CLI-only shell scripts (setup, update, backup, restore, export — none run in Cowork)
#   - The Claude Code marketplace manifest (.claude-plugin/marketplace.json)
#   - Maintainer-only docs (CLAUDE.md)

cd "$COUNSEL_DIR"
rm -f "$OUTPUT_FILE"

zip -r "$OUTPUT_FILE" . \
  -x ".git/*" \
  -x ".git" \
  -x ".gitignore" \
  -x ".claude/*" \
  -x ".claude" \
  -x ".mcp.json" \
  -x ".source-repo" \
  -x ".content-versions.json" \
  -x ".claude-plugin/marketplace.json" \
  -x "node_modules/*" \
  -x "browse/*" \
  -x "browse" \
  -x "scripts/*" \
  -x "scripts" \
  -x "backups/*" \
  -x "backups" \
  -x "docs/*" \
  -x "docs" \
  -x "bun.lock" \
  -x "*.bun-build" \
  -x ".DS_Store" \
  -x "**/.DS_Store" \
  -x "CLAUDE.md" \
  -x "config.local.md" \
  -x "setup" \
  -x "update" \
  -x "backup" \
  -x "restore" \
  -x "export" \
  > /dev/null

SIZE="$(du -h "$OUTPUT_FILE" | cut -f1 | tr -d ' ')"

echo ""
echo "Exported: $OUTPUT_FILE ($SIZE)"
echo ""
echo "Includes:"
echo "  - Plugin manifest (.claude-plugin/plugin.json)"
echo "  - Primitives (primitives/)"
echo "  - Skills (skills/ — counsel, browse, retro, setup, update, export)"
echo "  - Knowledge (knowledge/law/, knowledge/practice-seed/)"
echo "  - Templates (templates/)"
echo "  - Default config (config.md)"
echo ""
echo "Excludes:"
echo "  - User-specific config (config.local.md, .claude/settings.local.json, .mcp.json)"
echo "  - CLI shell scripts (setup, update, backup, restore, export — Cowork can't run them)"
echo "  - scripts/ (Python redline pipeline — Claude Code only; Cowork uses markdown redlines)"
echo "  - Browse binary/source (CLI-only)"
echo "  - Dev metadata (.git, .gitignore, .content-versions.json, .source-repo)"
echo ""
echo "To install in Cowork:"
echo "  1. Open Claude Desktop → Cowork → Customize → Browse plugins"
echo "  2. Remove the old Counsel OS plugin (if installed)"
echo "  3. Upload $OUTPUT_FILE"
echo "  4. Run /counsel-os:setup to seed content into your vault"
