#!/usr/bin/env bash
set -euo pipefail

COUNSEL_DIR="$(cd "$(dirname "$0")" && pwd)"

# Fail fast if $HOME is unset or empty. The backup and pointer paths below are
# rooted at $HOME; an empty value would silently degrade them to root-relative
# paths (/.counsel-os/...) and read/write outside the user's home. set -u
# catches a fully unset HOME but not a set-but-empty one, so guard both.
if [ -z "${HOME:-}" ]; then
  echo "\$HOME is not set — refusing to run to avoid touching root-relative paths." >&2
  exit 1
fi

# Backups live OUTSIDE the plugin directory (see ./backup). The legacy
# location inside the plugin tree is still checked so pre-migration backups
# remain restorable.
BACKUP_DIR="$HOME/.counsel-os/backups"
LEGACY_BACKUP_DIR="$COUNSEL_DIR/backups"
LEGACY_RESTORE_DIRS=(law practice matters memory entities)
RESTORE_WORKDIR=""
STAGE_PATH=""
ROLLBACK_PATH=""
PRESERVE_RESTORE_WORKDIR=0
MOVED_TO_ROLLBACK=()
MOVED_TO_LIVE=()
EXISTED_BEFORE=()
RESTORE_ITEMS=()
REMOVE_ITEMS=()

cleanup_restore_workdir() {
  if [ -n "$RESTORE_WORKDIR" ] && [ -d "$RESTORE_WORKDIR" ]; then
    if [ "$PRESERVE_RESTORE_WORKDIR" -eq 1 ]; then
      echo "Restore work directory preserved for manual recovery: $RESTORE_WORKDIR" >&2
      return
    fi
    rm -rf "$RESTORE_WORKDIR"
  fi
}

contains_item() {
  local needle="$1"
  shift
  local item

  for item in "$@"; do
    if [ "$item" = "$needle" ]; then
      return 0
    fi
  done

  return 1
}

rollback_restore() {
  local status=$?
  local item
  local rollback_failed=0

  trap - ERR

  # Fail-safe FIRST: the work directory may hold the user's only copy of
  # pre-restore content. Preserve it unless rollback completes fully —
  # if this trap itself dies, the EXIT cleanup must not delete it.
  PRESERVE_RESTORE_WORKDIR=1

  if [ "${#MOVED_TO_ROLLBACK[@]}" -gt 0 ] || [ "${#MOVED_TO_LIVE[@]}" -gt 0 ]; then
    echo ""
    echo "Restore failed. Attempting to roll back previous content..." >&2

    # ${arr[@]+...} guards the empty-array expansion: bash 3.2 (stock macOS)
    # treats "${arr[@]}" on an empty array as unbound under `set -u`.
    for item in ${MOVED_TO_LIVE[@]+"${MOVED_TO_LIVE[@]}"}; do
      rm -rf "$LEGAL_ROOT/$item" || rollback_failed=1
    done

    for item in ${MOVED_TO_ROLLBACK[@]+"${MOVED_TO_ROLLBACK[@]}"}; do
      rm -rf "$LEGAL_ROOT/$item" || rollback_failed=1
      if [ -e "$ROLLBACK_PATH/$item" ]; then
        mv "$ROLLBACK_PATH/$item" "$LEGAL_ROOT/$item" || rollback_failed=1
      else
        echo "Missing rollback content for $item." >&2
        rollback_failed=1
      fi
    done

    if [ "$rollback_failed" -eq 1 ]; then
      echo "Rollback was incomplete; inspect the preserved work directory before retrying." >&2
    else
      PRESERVE_RESTORE_WORKDIR=0
    fi
  else
    # Nothing was moved yet — nothing irreplaceable in the work directory.
    PRESERVE_RESTORE_WORKDIR=0
  fi

  trap - EXIT
  cleanup_restore_workdir
  exit "$status"
}

trap rollback_restore ERR
trap cleanup_restore_workdir EXIT

is_backup_dir() {
  [ -f "$1/root/config.md" ] || [ -f "$1/config.md" ]
}

# Pick the newest COMPLETE backup. ./backup writes the manifest last (and
# stages under *.partial before the final rename), so a full-root directory
# without manifest.json is an interrupted copy — auto-picking it would
# silently restore a truncated vault over live content. Legacy-layout
# backups (config.md at top level) predate manifests and stay eligible as
# a fallback when no manifest-bearing backup exists.
newest_backup_in() {
  local base="$1"
  local candidate

  [ -d "$base" ] || return 1

  while IFS= read -r candidate; do
    candidate="${candidate%/}"
    case "$candidate" in *.partial) continue ;; esac
    if [ -f "$candidate/manifest.json" ] && is_backup_dir "$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done < <(ls -dt "$base"/*/ 2>/dev/null)

  while IFS= read -r candidate; do
    candidate="${candidate%/}"
    case "$candidate" in *.partial) continue ;; esac
    if [ ! -d "$candidate/root" ] && [ -f "$candidate/config.md" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done < <(ls -dt "$base"/*/ 2>/dev/null)

  return 1
}

LEGAL_ROOT="$(bash "$COUNSEL_DIR/scripts/resolve_legal_root.sh" || true)"

if [ -z "$LEGAL_ROOT" ]; then
  echo "Legal root not found."
  echo "Run /counsel-os:setup, or set COUNSEL_OS_LEGAL_ROOT=/path/to/legal/root."
  exit 1
fi

if [ -n "${1:-}" ]; then
  if [ -d "$BACKUP_DIR/$1" ]; then
    BACKUP_PATH="$BACKUP_DIR/$1"
  elif [ -d "$LEGACY_BACKUP_DIR/$1" ]; then
    BACKUP_PATH="$LEGACY_BACKUP_DIR/$1"
    echo "Note: using backup from the legacy location inside the plugin directory:"
    echo "  $BACKUP_PATH"
    echo "Backups there are lost on plugin update. Run ./backup once to migrate them to $BACKUP_DIR."
  elif [ -d "$1" ]; then
    BACKUP_PATH="$1"
  else
    echo "Backup not found: $1"
    echo "Looked in: $BACKUP_DIR and $LEGACY_BACKUP_DIR"
    echo "Usage: ./restore [backup-name-or-path]"
    exit 1
  fi
else
  BACKUP_PATH="$(newest_backup_in "$BACKUP_DIR" || true)"
  if [ -z "$BACKUP_PATH" ]; then
    BACKUP_PATH="$(newest_backup_in "$LEGACY_BACKUP_DIR" || true)"
    if [ -n "$BACKUP_PATH" ]; then
      echo "Note: no backups in $BACKUP_DIR; using backup from the legacy location inside the plugin directory:"
      echo "  $BACKUP_PATH"
      echo "Backups there are lost on plugin update. Run ./backup once to migrate them to $BACKUP_DIR."
    fi
  fi
  if [ -z "$BACKUP_PATH" ]; then
    echo "No backups found in $BACKUP_DIR (or legacy $LEGACY_BACKUP_DIR)."
    echo "Run ./backup first to create one."
    exit 1
  fi
fi

# Two layouts: full-root backups carry the entire legal root under root/;
# legacy backups carry config.md plus the default subdirectories at top level.
if [ -f "$BACKUP_PATH/root/config.md" ]; then
  BACKUP_FORMAT="full-root"
  PAYLOAD_PATH="$BACKUP_PATH/root"
else
  BACKUP_FORMAT="legacy"
  PAYLOAD_PATH="$BACKUP_PATH"
fi

if [ ! -f "$PAYLOAD_PATH/config.md" ] || ! grep -q '^counsel-os-config: true$' "$PAYLOAD_PATH/config.md"; then
  echo "Backup is not a marked Counsel OS backup: $BACKUP_PATH"
  exit 1
fi

echo "Restoring from: $(basename "$BACKUP_PATH")"
echo "Restoring to:   $LEGAL_ROOT"

if [ -f "$BACKUP_PATH/manifest.json" ]; then
  echo "  backed up at version: $(grep -o '"version": "[^"]*"' "$BACKUP_PATH/manifest.json" | cut -d'"' -f4)"
  echo "  current version:      $(cat "$COUNSEL_DIR/VERSION" 2>/dev/null || echo "unknown")"
fi

# Sanity-check completeness BEFORE touching the legal root: an interrupted
# copy can hold a valid config.md but a truncated payload. Explicitly-named
# backups may still be restored after a confirmation (salvage), but never
# silently.
confirm_incomplete_backup() {
  echo ""
  echo "WARNING: $1"
  echo "Restoring it would replace live content with an incomplete copy."
  read -r -p "Restore it anyway? (y/N) " confirm
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    echo "Restore cancelled."
    exit 0
  fi
}

if [ -f "$BACKUP_PATH/manifest.json" ]; then
  manifest_files="$(grep -o '"files":[[:space:]]*[0-9]*' "$BACKUP_PATH/manifest.json" | grep -o '[0-9]*$' || true)"
  actual_files="$(find "$PAYLOAD_PATH" -type f ! -name '.gitkeep' ! -path "$BACKUP_PATH/manifest.json" | wc -l | tr -d ' ')"
  if [ -n "$manifest_files" ] && [ "$manifest_files" != "$actual_files" ]; then
    confirm_incomplete_backup "This backup looks INCOMPLETE: its manifest records $manifest_files files but $actual_files are present."
  fi
elif [ "$BACKUP_FORMAT" = "full-root" ]; then
  confirm_incomplete_backup "This backup has no manifest.json — it is likely an interrupted (incomplete) backup."
fi

# Build the list of top-level items to restore. Never restore .git or
# leftover restore work directories, whatever the backup contains.
if [ "$BACKUP_FORMAT" = "full-root" ]; then
  shopt -s dotglob
  for entry in "$PAYLOAD_PATH"/*; do
    [ -e "$entry" ] || [ -L "$entry" ] || continue
    name="$(basename "$entry")"
    case "$name" in
      .git|.counsel-os-restore.*) continue ;;
    esac
    RESTORE_ITEMS+=("$name")
  done
  shopt -u dotglob
else
  RESTORE_ITEMS+=(config.md)
  for dir in "${LEGACY_RESTORE_DIRS[@]}"; do
    if [ -d "$PAYLOAD_PATH/$dir" ]; then
      RESTORE_ITEMS+=("$dir")
    elif [ -e "$LEGAL_ROOT/$dir" ]; then
      # Preserve legacy semantics: default dirs absent from the backup are
      # removed from the legal root.
      REMOVE_ITEMS+=("$dir")
    fi
  done
fi

has_existing=0
for item in ${RESTORE_ITEMS[@]+"${RESTORE_ITEMS[@]}"} ${REMOVE_ITEMS[@]+"${REMOVE_ITEMS[@]}"}; do
  if [ "$item" = "config.md" ]; then
    continue
  fi
  if [ -e "$LEGAL_ROOT/$item" ]; then
    has_existing=1
    break
  fi
done

if [ "$has_existing" -eq 1 ]; then
  echo ""
  echo "WARNING: Existing Counsel OS content found at legal root."
  echo "Restoring will replace the current copies of everything present in the"
  echo "backup. Content at the legal root that is not in the backup is kept"
  echo "(except legacy-format restores, which remove the default Counsel OS"
  echo "directories that are absent from the backup)."
  echo ""
  read -r -p "Continue? (y/N) " confirm
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    echo "Restore cancelled."
    exit 0
  fi
fi

mkdir -p "$LEGAL_ROOT"

# The work directory lives under the legal root so mv operations stay on the
# same filesystem. A hard kill may leave a .counsel-os-restore.* directory.
RESTORE_WORKDIR="$(mktemp -d "$LEGAL_ROOT/.counsel-os-restore.XXXXXX")"
STAGE_PATH="$RESTORE_WORKDIR/stage"
ROLLBACK_PATH="$RESTORE_WORKDIR/rollback"
mkdir -p "$STAGE_PATH"

for item in ${RESTORE_ITEMS[@]+"${RESTORE_ITEMS[@]}"}; do
  cp -R "$PAYLOAD_PATH/$item" "$STAGE_PATH/$item"
done

mkdir -p "$ROLLBACK_PATH"

for item in ${RESTORE_ITEMS[@]+"${RESTORE_ITEMS[@]}"} ${REMOVE_ITEMS[@]+"${REMOVE_ITEMS[@]}"}; do
  if [ -e "$LEGAL_ROOT/$item" ] || [ -L "$LEGAL_ROOT/$item" ]; then
    EXISTED_BEFORE+=("$item")
    mv "$LEGAL_ROOT/$item" "$ROLLBACK_PATH/$item"
    MOVED_TO_ROLLBACK+=("$item")
  fi
done

for item in ${RESTORE_ITEMS[@]+"${RESTORE_ITEMS[@]}"}; do
  mv "$STAGE_PATH/$item" "$LEGAL_ROOT/$item"
  MOVED_TO_LIVE+=("$item")
  if [ -d "$LEGAL_ROOT/$item" ]; then
    echo "  restored: $item/"
  else
    echo "  restored: $item"
  fi
done

for item in ${REMOVE_ITEMS[@]+"${REMOVE_ITEMS[@]}"}; do
  if contains_item "$item" ${EXISTED_BEFORE[@]+"${EXISTED_BEFORE[@]}"} && ! contains_item "$item" ${MOVED_TO_LIVE[@]+"${MOVED_TO_LIVE[@]}"}; then
    echo "  removed:  $item/ (not present in backup)"
  fi
done

# A backup restored to a different location must not carry the old path:
# rewrite legal_root in the restored config.md to the actual destination.
# (Done before the rollback dir is discarded, so a failure here still rolls
# back cleanly.)
CONFIG_FILE="$LEGAL_ROOT/config.md"
old_root="$(sed -n 's/^legal_root:[[:space:]]*//p' "$CONFIG_FILE" | head -1)"
if [ "$old_root" != "$LEGAL_ROOT" ]; then
  if grep -q '^legal_root:' "$CONFIG_FILE"; then
    awk -v root="$LEGAL_ROOT" '
      /^legal_root:/ && !done { print "legal_root: " root; done = 1; next }
      { print }
    ' "$CONFIG_FILE" > "$RESTORE_WORKDIR/config.md.tmp"
    mv "$RESTORE_WORKDIR/config.md.tmp" "$CONFIG_FILE"
  else
    printf 'legal_root: %s\n' "$LEGAL_ROOT" >> "$CONFIG_FILE"
  fi
  echo "  updated:  config.md legal_root -> $LEGAL_ROOT"
fi

# Keep the per-machine pointer cache in sync with where the content now lives.
POINTER_FILE="$HOME/.counsel-os/legal-root"
if [ -f "$POINTER_FILE" ]; then
  pointer="$(tr -d '\n' < "$POINTER_FILE")"
  if [ "$pointer" != "$LEGAL_ROOT" ]; then
    printf '%s' "$LEGAL_ROOT" > "$POINTER_FILE"
    echo "  updated:  ~/.counsel-os/legal-root pointer -> $LEGAL_ROOT"
  fi
fi

rm -rf "$ROLLBACK_PATH"

echo ""
echo "Restore complete."
