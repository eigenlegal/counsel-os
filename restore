#!/usr/bin/env bash
set -e

COUNSEL_DIR="$(cd "$(dirname "$0")" && pwd)"
BACKUP_DIR="$COUNSEL_DIR/backups"

# Read legal root: config.local.md first, then config.md
LEGAL_ROOT=""
if [ -f "$COUNSEL_DIR/config.local.md" ]; then
    LEGAL_ROOT=$(grep "^legal_root:" "$COUNSEL_DIR/config.local.md" | sed 's/^legal_root: *//')
fi
if [ -z "$LEGAL_ROOT" ] && [ -f "$COUNSEL_DIR/config.md" ]; then
    LEGAL_ROOT=$(grep "^legal_root:" "$COUNSEL_DIR/config.md" | sed 's/^legal_root: *//')
fi

if [ -z "$LEGAL_ROOT" ]; then
  echo "Legal root not configured. Check config.md."
  exit 1
fi

# ── Find backup to restore ──────────────────────────────────────────

if [ -n "$1" ]; then
  if [ -d "$BACKUP_DIR/$1" ]; then
    BACKUP_PATH="$BACKUP_DIR/$1"
  elif [ -d "$1" ]; then
    BACKUP_PATH="$1"
  else
    echo "Backup not found: $1"
    echo "Usage: ./restore [backup-name]"
    echo "       ./restore                  (restores most recent)"
    exit 1
  fi
else
  if [ ! -d "$BACKUP_DIR" ] || [ -z "$(ls -A "$BACKUP_DIR" 2>/dev/null)" ]; then
    echo "No backups found in $BACKUP_DIR"
    echo "Run ./backup first to create one."
    exit 1
  fi
  BACKUP_PATH="$(ls -dt "$BACKUP_DIR"/counsel-os-backup-* 2>/dev/null | head -1)"
  if [ -z "$BACKUP_PATH" ]; then
    echo "No backups found."
    exit 1
  fi
fi

# ── Show what we're restoring ────────────────────────────────────────

echo "Restoring from: $(basename "$BACKUP_PATH")"
echo "Restoring to:   $LEGAL_ROOT"

if [ -f "$BACKUP_PATH/manifest.json" ]; then
  echo "  backed up at version: $(grep -o '"version": "[^"]*"' "$BACKUP_PATH/manifest.json" | cut -d'"' -f4)"
  echo "  current version:      $(cat "$COUNSEL_DIR/VERSION" 2>/dev/null || echo "unknown")"
fi

# ── Check for existing content ───────────────────────────────────────

has_existing=0
for dir in practice memory law defaults; do
  if [ -d "$LEGAL_ROOT/$dir" ] && [ "$(find "$LEGAL_ROOT/$dir" -type f ! -name '.gitkeep' | head -1)" ]; then
    has_existing=1
    break
  fi
done

if [ "$has_existing" -eq 1 ]; then
  echo ""
  echo "WARNING: Existing content found at legal root."
  echo "Restoring will OVERWRITE current practice/, memory/, law/, and defaults/ files."
  echo ""
  read -p "Continue? (y/N) " confirm
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    echo "Restore cancelled."
    exit 0
  fi
fi

# ── Restore ──────────────────────────────────────────────────────────

for dir in practice memory law defaults; do
  if [ -d "$BACKUP_PATH/$dir" ]; then
    mkdir -p "$LEGAL_ROOT/$dir"
    cp -r "$BACKUP_PATH/$dir/"* "$LEGAL_ROOT/$dir/" 2>/dev/null || true
    echo "  restored: $dir/"
  fi
done

echo ""
echo "Restore complete."
