#!/usr/bin/env bash
set -euo pipefail

COUNSEL_DIR="$(cd "$(dirname "$0")" && pwd)"
BACKUP_DIR="$COUNSEL_DIR/backups"
RESTORE_DIRS=(law practice matters memory entities)
RESTORE_WORKDIR=""
STAGE_PATH=""
ROLLBACK_PATH=""
PRESERVE_RESTORE_WORKDIR=0
MOVED_TO_ROLLBACK=()
MOVED_TO_LIVE=()
EXISTED_BEFORE=()

cleanup_restore_workdir() {
  if [ -n "$RESTORE_WORKDIR" ] && [ -d "$RESTORE_WORKDIR" ]; then
    if [ "$PRESERVE_RESTORE_WORKDIR" -eq 1 ]; then
      echo "Restore work directory preserved for manual recovery: $RESTORE_WORKDIR" >&2
      return
    fi
    rm -rf "$RESTORE_WORKDIR"
  fi
}

contains_item() {
  local needle="$1"
  shift
  local item

  for item in "$@"; do
    if [ "$item" = "$needle" ]; then
      return 0
    fi
  done

  return 1
}

rollback_restore() {
  local status=$?
  local item
  local rollback_failed=0

  trap - ERR

  if [ "${#MOVED_TO_ROLLBACK[@]}" -gt 0 ] || [ "${#MOVED_TO_LIVE[@]}" -gt 0 ]; then
    echo ""
    echo "Restore failed. Attempting to roll back previous content..." >&2

    for item in "${MOVED_TO_LIVE[@]}"; do
      rm -rf "$LEGAL_ROOT/$item" || rollback_failed=1
    done

    for item in "${MOVED_TO_ROLLBACK[@]}"; do
      rm -rf "$LEGAL_ROOT/$item" || rollback_failed=1
      if [ -e "$ROLLBACK_PATH/$item" ]; then
        mv "$ROLLBACK_PATH/$item" "$LEGAL_ROOT/$item" || rollback_failed=1
      else
        echo "Missing rollback content for $item." >&2
        rollback_failed=1
      fi
    done

    if [ "$rollback_failed" -eq 1 ]; then
      PRESERVE_RESTORE_WORKDIR=1
      echo "Rollback was incomplete; inspect the preserved work directory before retrying." >&2
    fi
  fi

  trap - EXIT
  cleanup_restore_workdir
  exit "$status"
}

trap rollback_restore ERR
trap cleanup_restore_workdir EXIT

LEGAL_ROOT="$(bash "$COUNSEL_DIR/scripts/resolve_legal_root.sh" || true)"

if [ -z "$LEGAL_ROOT" ]; then
  echo "Legal root not found."
  echo "Run /counsel-os:setup, or set COUNSEL_OS_LEGAL_ROOT=/path/to/legal/root."
  exit 1
fi

if [ -n "${1:-}" ]; then
  if [ -d "$BACKUP_DIR/$1" ]; then
    BACKUP_PATH="$BACKUP_DIR/$1"
  elif [ -d "$1" ]; then
    BACKUP_PATH="$1"
  else
    echo "Backup not found: $1"
    echo "Usage: ./restore [backup-name-or-path]"
    exit 1
  fi
else
  if [ ! -d "$BACKUP_DIR" ] || [ -z "$(ls -A "$BACKUP_DIR" 2>/dev/null)" ]; then
    echo "No backups found in $BACKUP_DIR"
    echo "Run ./backup first to create one."
    exit 1
  fi
  BACKUP_PATH="$(ls -dt "$BACKUP_DIR"/counsel-os-backup-* 2>/dev/null | head -1)"
  if [ -z "$BACKUP_PATH" ]; then
    echo "No backups found."
    exit 1
  fi
fi

if [ ! -f "$BACKUP_PATH/config.md" ] || ! grep -q '^counsel-os-config: true$' "$BACKUP_PATH/config.md"; then
  echo "Backup is not a marked Counsel OS backup: $BACKUP_PATH"
  exit 1
fi

echo "Restoring from: $(basename "$BACKUP_PATH")"
echo "Restoring to:   $LEGAL_ROOT"

if [ -f "$BACKUP_PATH/manifest.json" ]; then
  echo "  backed up at version: $(grep -o '"version": "[^"]*"' "$BACKUP_PATH/manifest.json" | cut -d'"' -f4)"
  echo "  current version:      $(cat "$COUNSEL_DIR/VERSION" 2>/dev/null || echo "unknown")"
fi

has_existing=0
for dir in "${RESTORE_DIRS[@]}"; do
  if [ -d "$LEGAL_ROOT/$dir" ] && [ "$(find "$LEGAL_ROOT/$dir" -type f ! -name '.gitkeep' | head -1)" ]; then
    has_existing=1
    break
  fi
done

if [ "$has_existing" -eq 1 ]; then
  echo ""
  echo "WARNING: Existing Counsel OS content found at legal root."
  echo "Restoring will replace current law/, practice/, matters/, memory/, and entities/"
  echo "with the backup contents. Files not present in the backup will be removed."
  echo ""
  read -r -p "Continue? (y/N) " confirm
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    echo "Restore cancelled."
    exit 0
  fi
fi

mkdir -p "$LEGAL_ROOT"

# The work directory lives under the legal root so mv operations stay on the
# same filesystem. A hard kill may leave a .counsel-os-restore.* directory.
RESTORE_WORKDIR="$(mktemp -d "$LEGAL_ROOT/.counsel-os-restore.XXXXXX")"
STAGE_PATH="$RESTORE_WORKDIR/stage"
ROLLBACK_PATH="$RESTORE_WORKDIR/rollback"
mkdir -p "$STAGE_PATH"

cp "$BACKUP_PATH/config.md" "$STAGE_PATH/config.md"

for dir in "${RESTORE_DIRS[@]}"; do
  if [ -d "$BACKUP_PATH/$dir" ]; then
    cp -R "$BACKUP_PATH/$dir" "$STAGE_PATH/$dir"
  fi
done

mkdir -p "$ROLLBACK_PATH"

for item in config.md "${RESTORE_DIRS[@]}"; do
  if [ -e "$LEGAL_ROOT/$item" ]; then
    EXISTED_BEFORE+=("$item")
    mv "$LEGAL_ROOT/$item" "$ROLLBACK_PATH/$item"
    MOVED_TO_ROLLBACK+=("$item")
  fi
done

mv "$STAGE_PATH/config.md" "$LEGAL_ROOT/config.md"
MOVED_TO_LIVE+=("config.md")

for dir in "${RESTORE_DIRS[@]}"; do
  if [ -d "$STAGE_PATH/$dir" ]; then
    mv "$STAGE_PATH/$dir" "$LEGAL_ROOT/$dir"
    MOVED_TO_LIVE+=("$dir")
    echo "  restored: $dir/"
  elif contains_item "$dir" "${EXISTED_BEFORE[@]}"; then
    echo "  removed:  $dir/ (not present in backup)"
  fi
done

rm -rf "$ROLLBACK_PATH"

echo ""
echo "Restore complete."
