#!/bin/bash
set -euo pipefail

# Find the Counsel OS browse binary. Echoes path and exits 0, or exits 1 if not found.
#
# Search order: repo root build -> plugin root build -> ~/counsel-os build
# -> ~/.counsel-os prior download -> download a prebuilt binary from the
# GitHub release matching this plugin's VERSION (fallback: latest release).
#
# Downloaded installs also fetch two companion assets when missing:
#   - counsel-browse-runtime.tar.gz: the playwright packages the binary
#     resolves at startup (playwright is external in the compiled binary —
#     bundling it bakes build-host absolute paths). Extracted as node_modules/
#     two directories above the binary, mirroring the dev layout.
#   - counsel-browse-{platform}-browsers.tar.gz: the matching Chromium builds,
#     extracted into the ms-playwright cache.
# Together these make machines with no bun/node toolchain fully working.
# Set COUNSEL_OS_NO_DOWNLOAD=1 to disable all download fallbacks (airgapped /
# build-from-source-only installs).
#
# bash-3.2 compatible (stock macOS).

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"

REPO_URL="https://github.com/eigenlegal/counsel-os"
VERSION="$(cat "$PLUGIN_ROOT/VERSION" 2>/dev/null | tr -d '[:space:]' || true)"

# Prebuilt binaries ship for Apple-Silicon macOS and Linux-x64 only. Intel
# Macs (Darwin-x86_64) have no prebuilt: the release workflow can't produce a
# working darwin-x64 asset (see release-binaries.yml). Leaving ASSET empty
# routes them to the honest "build from source" message rather than a doomed
# download of a nonexistent asset.
case "$(uname -s)-$(uname -m)" in
  Darwin-arm64)             ASSET="counsel-browse-darwin-arm64" ;;
  Linux-x86_64|Linux-amd64) ASSET="counsel-browse-linux-x64" ;;
  *)                        ASSET="" ;;
esac

# Candidate release URLs for an asset name: this plugin's version first, then
# the latest release (covers the window where a fresh release is still building).
release_urls() {
  [ -n "$VERSION" ] && echo "$REPO_URL/releases/download/v$VERSION/$1"
  echo "$REPO_URL/releases/latest/download/$1"
}

# Download a release asset to a temp file and echo the temp path; non-zero on failure.
fetch_asset() {
  local tmp url
  tmp="$(mktemp "${TMPDIR:-/tmp}/counsel-asset.XXXXXX")"
  for url in $(release_urls "$1"); do
    if curl -fSL --retry 2 --connect-timeout 10 -o "$tmp" "$url" 2>/dev/null; then
      echo "$tmp"
      return 0
    fi
  done
  rm -f "$tmp"
  return 1
}

# Ensure the playwright runtime exists for a downloaded binary at $1.
# The compiled binary resolves playwright/playwright-core from node_modules
# two directories above itself ({base}/browse/dist/browse -> {base}/node_modules).
ensure_runtime() {
  [ "${COUNSEL_OS_NO_DOWNLOAD:-0}" = "1" ] && return 0
  local base tmp
  base="$(cd "$(dirname "$1")/../.." && pwd)"
  [ -d "$base/node_modules/playwright-core" ] && return 0
  echo "playwright runtime not installed — downloading counsel-browse-runtime.tar.gz (~5MB)..." >&2
  if tmp="$(fetch_asset "counsel-browse-runtime.tar.gz")"; then
    if tar -xzf "$tmp" -C "$base" 2>/dev/null; then
      rm -f "$tmp"
      echo "installed playwright runtime into $base/node_modules" >&2
      return 0
    fi
    rm -f "$tmp"
  fi
  echo "WARNING: could not download the playwright runtime — the browse daemon will fail to start. Build from source with: bun install && bun run build" >&2
  return 0
}

# Ensure the Playwright browser builds exist. Best-effort: on failure, print
# guidance and return 0 so the binary path is still usable.
ensure_browsers() {
  [ "${COUNSEL_OS_NO_DOWNLOAD:-0}" = "1" ] && return 0
  local cache tmp
  if [ -n "${PLAYWRIGHT_BROWSERS_PATH:-}" ]; then
    cache="$PLAYWRIGHT_BROWSERS_PATH"
  elif [ "$(uname -s)" = "Darwin" ]; then
    cache="$HOME/Library/Caches/ms-playwright"
  else
    cache="${XDG_CACHE_HOME:-$HOME/.cache}/ms-playwright"
  fi
  ls "$cache"/chromium-* >/dev/null 2>&1 && return 0
  [ -n "$ASSET" ] || return 0
  echo "Playwright Chromium not installed — downloading matching browser builds (~250MB, one time)..." >&2
  if tmp="$(fetch_asset "$ASSET-browsers.tar.gz")"; then
    mkdir -p "$cache"
    if tar -xzf "$tmp" -C "$cache" 2>/dev/null; then
      rm -f "$tmp"
      echo "installed Playwright browsers into $cache" >&2
      return 0
    fi
    rm -f "$tmp"
  fi
  echo "WARNING: could not download browser builds. Install manually with: bunx playwright install chromium" >&2
  return 0
}

if [ -n "$ROOT" ] && test -x "$ROOT/browse/dist/browse"; then
  echo "$ROOT/browse/dist/browse"
  exit 0
elif test -x "$PLUGIN_ROOT/browse/dist/browse"; then
  ensure_runtime "$PLUGIN_ROOT/browse/dist/browse"
  ensure_browsers
  echo "$PLUGIN_ROOT/browse/dist/browse"
  exit 0
elif test -x "$HOME/counsel-os/browse/dist/browse"; then
  echo "$HOME/counsel-os/browse/dist/browse"
  exit 0
elif test -x "$HOME/.counsel-os/browse/dist/browse"; then
  ensure_runtime "$HOME/.counsel-os/browse/dist/browse"
  ensure_browsers
  echo "$HOME/.counsel-os/browse/dist/browse"
  exit 0
fi

# --- No local binary: try the prebuilt-release fallback -----------------------

fail() {
  echo "ERROR: browse binary not found. Run /counsel-os:setup or build with: bun run build" >&2
  exit 1
}

[ "${COUNSEL_OS_NO_DOWNLOAD:-0}" = "1" ] && fail
command -v curl >/dev/null 2>&1 || fail
if [ -z "$ASSET" ]; then
  echo "ERROR: no prebuilt browse binary for $(uname -s)/$(uname -m). Build with: bun run build" >&2
  exit 1
fi

# Prefer installing next to the plugin (versioned cache dir); fall back to
# ~/.counsel-os when the plugin tree is not writable. Either way the binary
# lands at {base}/browse/dist/browse so the runtime geometry stays uniform.
BASE="$PLUGIN_ROOT"
if ! mkdir -p "$BASE/browse/dist" 2>/dev/null || ! [ -w "$BASE/browse/dist" ]; then
  BASE="$HOME/.counsel-os"
  mkdir -p "$BASE/browse/dist"
fi
DEST="$BASE/browse/dist/browse"

echo "browse binary not built locally — downloading prebuilt $ASSET (~65-100MB, one time)..." >&2
if TMP="$(fetch_asset "$ASSET")"; then
  chmod +x "$TMP"
  mv "$TMP" "$DEST"
  # The runtime must be in place BEFORE the smoke test: the binary resolves
  # playwright at startup, so even --help fails without node_modules.
  ensure_runtime "$DEST"
  if "$DEST" --help >/dev/null 2>&1; then
    echo "installed prebuilt browse binary at $DEST" >&2
    ensure_browsers
    echo "$DEST"
    exit 0
  fi
  rm -f "$DEST"
  echo "downloaded binary failed its smoke test (wrong platform or incomplete runtime) — removed" >&2
fi

fail
