#!/usr/bin/env bash
set -euo pipefail

COUNSEL_DIR="$(cd "$(dirname "$0")" && pwd)"
BACKUP_DIR="$COUNSEL_DIR/backups"
TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
BACKUP_NAME="counsel-os-backup-$TIMESTAMP"
BACKUP_PATH="$BACKUP_DIR/$BACKUP_NAME"

LEGAL_ROOT="$(bash "$COUNSEL_DIR/scripts/resolve_legal_root.sh" || true)"

if [ -z "$LEGAL_ROOT" ] || [ ! -d "$LEGAL_ROOT" ]; then
  echo "Legal root not found."
  echo "Run /counsel-os:setup, or set COUNSEL_OS_LEGAL_ROOT=/path/to/legal/root."
  exit 1
fi

if [ ! -f "$LEGAL_ROOT/config.md" ] || ! grep -q '^counsel-os-config: true$' "$LEGAL_ROOT/config.md"; then
  echo "Not a marked Counsel OS legal root: $LEGAL_ROOT"
  echo "Expected $LEGAL_ROOT/config.md to contain: counsel-os-config: true"
  exit 1
fi

has_content=0
for dir in law practice matters memory entities; do
  if [ -d "$LEGAL_ROOT/$dir" ] && [ "$(find "$LEGAL_ROOT/$dir" -type f ! -name '.gitkeep' | head -1)" ]; then
    has_content=1
    break
  fi
done

if [ "$has_content" -eq 0 ]; then
  echo "Nothing to back up. Run /counsel-os:setup first."
  exit 0
fi

mkdir -p "$BACKUP_PATH"

for dir in law practice matters memory entities; do
  if [ -d "$LEGAL_ROOT/$dir" ]; then
    cp -R "$LEGAL_ROOT/$dir" "$BACKUP_PATH/$dir"
  fi
done

cp "$LEGAL_ROOT/config.md" "$BACKUP_PATH/config.md"

cat > "$BACKUP_PATH/manifest.json" << MANIFEST
{
  "timestamp": "$TIMESTAMP",
  "version": "$(cat "$COUNSEL_DIR/VERSION" 2>/dev/null || echo "unknown")",
  "source": "$LEGAL_ROOT",
  "contents": {
    "law": $([ -d "$BACKUP_PATH/law" ] && find "$BACKUP_PATH/law" -type f ! -name '.gitkeep' | wc -l | tr -d ' ' || echo 0),
    "practice": $([ -d "$BACKUP_PATH/practice" ] && find "$BACKUP_PATH/practice" -type f ! -name '.gitkeep' | wc -l | tr -d ' ' || echo 0),
    "matters": $([ -d "$BACKUP_PATH/matters" ] && find "$BACKUP_PATH/matters" -type f ! -name '.gitkeep' | wc -l | tr -d ' ' || echo 0),
    "memory": $([ -d "$BACKUP_PATH/memory" ] && find "$BACKUP_PATH/memory" -type f ! -name '.gitkeep' | wc -l | tr -d ' ' || echo 0),
    "entities": $([ -d "$BACKUP_PATH/entities" ] && find "$BACKUP_PATH/entities" -type f ! -name '.gitkeep' | wc -l | tr -d ' ' || echo 0)
  }
}
MANIFEST

echo "Backup created: $BACKUP_PATH"
echo "  source:   $LEGAL_ROOT"
echo "  law:      $(grep -o '"law": [0-9]*' "$BACKUP_PATH/manifest.json" | grep -o '[0-9]*') files"
echo "  practice: $(grep -o '"practice": [0-9]*' "$BACKUP_PATH/manifest.json" | grep -o '[0-9]*') files"
echo "  matters:  $(grep -o '"matters": [0-9]*' "$BACKUP_PATH/manifest.json" | grep -o '[0-9]*') files"
echo "  memory:   $(grep -o '"memory": [0-9]*' "$BACKUP_PATH/manifest.json" | grep -o '[0-9]*') files"
echo "  entities: $(grep -o '"entities": [0-9]*' "$BACKUP_PATH/manifest.json" | grep -o '[0-9]*') files"
