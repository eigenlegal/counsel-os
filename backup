#!/usr/bin/env bash
set -euo pipefail

COUNSEL_DIR="$(cd "$(dirname "$0")" && pwd)"
BACKUP_DIR="$COUNSEL_DIR/backups"
TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
BACKUP_NAME="counsel-os-backup-$TIMESTAMP"
BACKUP_PATH="$BACKUP_DIR/$BACKUP_NAME"

LEGAL_ROOT="$(bash "$COUNSEL_DIR/scripts/resolve_legal_root.sh" || true)"

if [ -z "$LEGAL_ROOT" ] || [ ! -d "$LEGAL_ROOT" ]; then
  echo "Legal root not found."
  echo "Run /counsel-os:setup, or set COUNSEL_OS_LEGAL_ROOT=/path/to/legal/root."
  exit 1
fi

if [ ! -f "$LEGAL_ROOT/config.md" ] || ! grep -q '^counsel-os-config: true$' "$LEGAL_ROOT/config.md"; then
  echo "Not a marked Counsel OS legal root: $LEGAL_ROOT"
  echo "Expected $LEGAL_ROOT/config.md to contain: counsel-os-config: true"
  exit 1
fi

has_content=0
for dir in law practice matters memory entities; do
  if [ -d "$LEGAL_ROOT/$dir" ] && [ "$(find "$LEGAL_ROOT/$dir" -type f ! -name '.gitkeep' | head -1)" ]; then
    has_content=1
    break
  fi
done

if [ "$has_content" -eq 0 ]; then
  echo "Nothing to back up. Run /counsel-os:setup first."
  exit 0
fi

mkdir -p "$BACKUP_PATH"

for dir in law practice matters memory entities; do
  if [ -d "$LEGAL_ROOT/$dir" ]; then
    cp -R "$LEGAL_ROOT/$dir" "$BACKUP_PATH/$dir"
  fi
done

cp "$LEGAL_ROOT/config.md" "$BACKUP_PATH/config.md"

count_files() {
  local dir="$1"
  if [ -d "$BACKUP_PATH/$dir" ]; then
    find "$BACKUP_PATH/$dir" -type f ! -name '.gitkeep' | wc -l | tr -d ' '
  else
    echo 0
  fi
}

VERSION="$(cat "$COUNSEL_DIR/VERSION" 2>/dev/null || echo "unknown")"
LAW_COUNT="$(count_files law)"
PRACTICE_COUNT="$(count_files practice)"
MATTERS_COUNT="$(count_files matters)"
MEMORY_COUNT="$(count_files memory)"
ENTITIES_COUNT="$(count_files entities)"

python3 - "$BACKUP_PATH/manifest.json" "$TIMESTAMP" "$VERSION" "$LEGAL_ROOT" \
  "$LAW_COUNT" "$PRACTICE_COUNT" "$MATTERS_COUNT" "$MEMORY_COUNT" "$ENTITIES_COUNT" <<'PY'
import json
import sys

manifest_path, timestamp, version, source, law, practice, matters, memory, entities = sys.argv[1:]
manifest = {
    "timestamp": timestamp,
    "version": version,
    "source": source,
    "contents": {
        "law": int(law),
        "practice": int(practice),
        "matters": int(matters),
        "memory": int(memory),
        "entities": int(entities),
    },
}

with open(manifest_path, "w", encoding="utf-8") as f:
    json.dump(manifest, f, indent=2)
    f.write("\n")
PY

echo "Backup created: $BACKUP_PATH"
echo "  source:   $LEGAL_ROOT"
echo "  law:      $LAW_COUNT files"
echo "  practice: $PRACTICE_COUNT files"
echo "  matters:  $MATTERS_COUNT files"
echo "  memory:   $MEMORY_COUNT files"
echo "  entities: $ENTITIES_COUNT files"
