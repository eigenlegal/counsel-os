#!/usr/bin/env bash
set -e

# Counsel OS — Update Script
# Pulls latest product content (law/, defaults/, skills/, templates/) without
# touching user data (practice/, matters/, memory/).
#
# Works in two modes:
#   1. Git repo (development install) — git fetch && git merge
#   2. Plugin cache (installed via registry) — find the git source repo,
#      pull there, then rsync product content into the cache

COUNSEL_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$COUNSEL_DIR"

# Portable content hash (macOS uses md5, Linux uses md5sum)
# Hashes all files in a directory into a single checksum
_dir_hash() {
    local dir="$1"
    if command -v md5 &>/dev/null; then
        find "$dir" -type f -print0 | sort -z | xargs -0 md5 -q 2>/dev/null | md5 -q 2>/dev/null || echo "skip"
    elif command -v md5sum &>/dev/null; then
        find "$dir" -type f -print0 | sort -z | xargs -0 md5sum 2>/dev/null | awk '{print $1}' | md5sum | awk '{print $1}' || echo "skip"
    else
        echo "skip"
    fi
}

echo "Counsel OS Update"
echo "================="
echo ""

# -------------------------------------------------------------------
# Step 1: Store current version
# -------------------------------------------------------------------

OLD_VERSION="unknown"
if [ -f "$COUNSEL_DIR/VERSION" ]; then
    OLD_VERSION=$(cat "$COUNSEL_DIR/VERSION")
fi
echo "Current version: $OLD_VERSION"
echo ""

# -------------------------------------------------------------------
# Step 2: User data is in Obsidian vault — no cache backup needed
# -------------------------------------------------------------------

# User data lives at: /Users/jackwang/Documents/Obsidian Vault/Counsel OS/
# Product updates do not touch it. Backup via Obsidian sync or ./backup script.

# -------------------------------------------------------------------
# Step 3: Determine update mode and pull latest
# -------------------------------------------------------------------

echo "Pulling latest changes..."
echo ""

# Product content directories to sync (everything EXCEPT user data)
PRODUCT_DIRS=(
    "knowledge/defaults"
    "knowledge/law"
    "skills"
    "templates"
)

# Top-level product files to sync
PRODUCT_FILES=(
    "VERSION"
    "CLAUDE.md"
    "CONNECTORS.md"
    "README.md"
    "update"
    "backup"
    "restore"
    "setup"
    "package.json"
    "config.md"
    ".claude-plugin/plugin.json"
)

if git rev-parse --is-inside-work-tree &>/dev/null; then
    # ---------------------------------------------------------------
    # Mode 1: Git repo — standard git pull
    # ---------------------------------------------------------------
    echo "Mode: git repo"
    echo ""

    OLD_COMMIT=$(git rev-parse HEAD 2>/dev/null || echo "")

    git fetch origin 2>&1 | head -5
    git merge origin/main --no-edit 2>&1 | head -10

    NEW_COMMIT=$(git rev-parse HEAD 2>/dev/null || echo "")

    echo ""

    if [ -n "$OLD_COMMIT" ] && [ -n "$NEW_COMMIT" ] && [ "$OLD_COMMIT" != "$NEW_COMMIT" ]; then
        echo "Changes in product content:"
        echo "----------------------------"

        for pdir in "${PRODUCT_DIRS[@]}"; do
            CHANGES=$(git diff --name-status "$OLD_COMMIT".."$NEW_COMMIT" -- "$pdir/" 2>/dev/null || echo "")
            if [ -n "$CHANGES" ]; then
                echo ""
                echo "$pdir/:"
                echo "$CHANGES" | while IFS=$'\t' read -r status file; do
                    case "$status" in
                        A) echo "  + NEW: $file" ;;
                        M) echo "  ~ UPDATED: $file" ;;
                        D) echo "  - REMOVED: $file" ;;
                        *) echo "  ? $status: $file" ;;
                    esac
                done
            fi
        done
    else
        echo "Already up to date — no changes pulled."
    fi
else
    # ---------------------------------------------------------------
    # Mode 2: Plugin cache — find git source, pull there, rsync here
    # ---------------------------------------------------------------
    echo "Mode: plugin cache (not a git repo)"
    echo ""

    # Find the git source repo
    SOURCE_DIR=""

    # Check configurable path first
    if [ -f "$COUNSEL_DIR/.source-repo" ]; then
        CONFIGURED=$(cat "$COUNSEL_DIR/.source-repo" | tr -d '[:space:]')
        if [ -d "$CONFIGURED/.git" ] && [ -f "$CONFIGURED/VERSION" ]; then
            SOURCE_DIR="$CONFIGURED"
        fi
    fi

    # Search known locations
    if [ -z "$SOURCE_DIR" ]; then
        for candidate in \
            "$HOME/Desktop/counsel-os" \
            "$HOME/counsel-os" \
            "$HOME/dev/counsel-os" \
            "$HOME/src/counsel-os" \
            "$HOME/code/counsel-os" \
            "$HOME/projects/counsel-os"; do
            if [ -d "$candidate/.git" ] && [ -f "$candidate/VERSION" ]; then
                SOURCE_DIR="$candidate"
                break
            fi
        done
    fi

    if [ -z "$SOURCE_DIR" ]; then
        echo "ERROR: Cannot find counsel-os git repo to pull from."
        echo ""
        echo "The plugin cache at:"
        echo "  $COUNSEL_DIR"
        echo "is not a git repo, so we need the source repo to sync from."
        echo ""
        echo "To fix this, create a file at:"
        echo "  $COUNSEL_DIR/.source-repo"
        echo "containing the absolute path to your counsel-os git clone."
        echo ""
        echo "Example:"
        echo "  echo '$HOME/Desktop/counsel-os' > '$COUNSEL_DIR/.source-repo'"
        exit 1
    fi

    echo "Source repo: $SOURCE_DIR"
    echo ""

    # Pull latest in the source repo
    echo "Pulling latest in source repo..."
    (cd "$SOURCE_DIR" && git fetch origin 2>&1 | head -5 && git merge origin/main --no-edit 2>&1 | head -10)
    echo ""

    # Sync product content from source to cache
    echo "Syncing product content to plugin cache..."
    echo ""

    CHANGED_COUNT=0

    for pdir in "${PRODUCT_DIRS[@]}"; do
        if [ -d "$SOURCE_DIR/$pdir" ]; then
            # Create target dir if needed
            mkdir -p "$COUNSEL_DIR/$pdir"
            # Rsync with delete to remove stale files, but only product dirs
            rsync -a --delete "$SOURCE_DIR/$pdir/" "$COUNSEL_DIR/$pdir/" 2>/dev/null
            echo "  synced: $pdir/"
            CHANGED_COUNT=$((CHANGED_COUNT + 1))
        fi
    done

    for pfile in "${PRODUCT_FILES[@]}"; do
        if [ -f "$SOURCE_DIR/$pfile" ]; then
            if [ "$pfile" = "update" ]; then
                # Self-update: copy to temp file first, then atomic move.
                # Overwriting a running bash script corrupts the process.
                cp "$SOURCE_DIR/$pfile" "$COUNSEL_DIR/$pfile.tmp"
                mv -f "$COUNSEL_DIR/$pfile.tmp" "$COUNSEL_DIR/$pfile"
                chmod +x "$COUNSEL_DIR/$pfile"
            else
                cp "$SOURCE_DIR/$pfile" "$COUNSEL_DIR/$pfile"
            fi
        fi
    done

    # Sync browse binary if it exists
    if [ -d "$SOURCE_DIR/browse" ]; then
        rsync -a "$SOURCE_DIR/browse/" "$COUNSEL_DIR/browse/" 2>/dev/null
        echo "  synced: browse/"
    fi

    echo ""
    echo "Synced $CHANGED_COUNT product directories + top-level files."

    # Save source path for future upgrades
    echo "$SOURCE_DIR" > "$COUNSEL_DIR/.source-repo"
fi

echo ""

# -------------------------------------------------------------------
# Step 4: Show new version
# -------------------------------------------------------------------

NEW_VERSION="unknown"
if [ -f "$COUNSEL_DIR/VERSION" ]; then
    NEW_VERSION=$(cat "$COUNSEL_DIR/VERSION")
fi

if [ "$OLD_VERSION" != "$NEW_VERSION" ]; then
    echo "Version: $OLD_VERSION -> $NEW_VERSION"
else
    echo "Version: $NEW_VERSION (unchanged)"
fi

echo ""

# -------------------------------------------------------------------
# Step 5: Verify user content is untouched
# -------------------------------------------------------------------

echo "User content location:"
echo "----------------------"
echo "  User data lives in Obsidian vault (not in plugin cache)."
echo "  Path: /Users/jackwang/Documents/Obsidian Vault/Counsel OS/"
echo "  Product content updates do not affect user data."
echo ""
echo "Update complete."

echo ""
