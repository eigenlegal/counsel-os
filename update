#!/usr/bin/env bash
set -e

# Counsel OS — Update Script
# Pulls latest product content (law/, defaults/, skills/, templates/) without
# touching user data (practice/, matters/, memory/).
#
# Works in two modes:
#   1. Git repo (development install) — git fetch && git merge
#   2. Plugin cache (installed via registry) — find the git source repo,
#      pull there, then sync into a versioned subdirectory. Updates
#      installed_plugins.json so Claude Code picks up the new version.
#      Keeps the last 3 versions for rollback; prunes older ones.

COUNSEL_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$COUNSEL_DIR"

INSTALLED_PLUGINS="$HOME/.claude/plugins/installed_plugins.json"
KEEP_VERSIONS=3

# Auto-detect plugin key by matching any "counsel-os@<marketplace>" entry
# (works for eigenlegal, jack-plugins, or any custom marketplace name)
PLUGIN_KEY=""
if [ -f "$INSTALLED_PLUGINS" ] && command -v python3 &>/dev/null; then
    PLUGIN_KEY=$(python3 -c "
import json, sys
with open('$INSTALLED_PLUGINS') as f:
    data = json.load(f)
for key in data.get('plugins', {}):
    if key.startswith('counsel-os@'):
        print(key)
        break
")
fi
PLUGIN_KEY="${PLUGIN_KEY:-counsel-os@eigenlegal}"

echo "Counsel OS Update"
echo "================="
echo ""

# -------------------------------------------------------------------
# Step 1: Store current version
# -------------------------------------------------------------------

OLD_VERSION="unknown"
if [ -f "$COUNSEL_DIR/VERSION" ]; then
    OLD_VERSION=$(cat "$COUNSEL_DIR/VERSION")
fi
echo "Current version: $OLD_VERSION"
echo ""

# -------------------------------------------------------------------
# Step 2: User data is in Obsidian vault — no cache backup needed
# -------------------------------------------------------------------

# User data lives in the Obsidian vault (not in plugin cache).
# Product updates do not touch it. Backup via Obsidian sync or ./backup script.

# -------------------------------------------------------------------
# Step 3: Determine update mode and pull latest
# -------------------------------------------------------------------

echo "Pulling latest changes..."
echo ""

# Product content directories to sync (everything EXCEPT user data)
PRODUCT_DIRS=(
    "knowledge/practice-seed"
    "knowledge/law"
    "skills"
    "templates"
)

# Top-level product files to sync
PRODUCT_FILES=(
    "VERSION"
    "CONNECTORS.md"
    "README.md"
    "backup"
    "restore"
    "setup"
    "export"
    "package.json"
    "config.md"
    ".claude-plugin/plugin.json"
)

if git rev-parse --is-inside-work-tree &>/dev/null; then
    # ---------------------------------------------------------------
    # Mode 1: Git repo — standard git pull (development install)
    # ---------------------------------------------------------------
    echo "Mode: git repo"
    echo ""

    OLD_COMMIT=$(git rev-parse HEAD 2>/dev/null || echo "")

    git fetch origin 2>&1 | head -5
    git merge origin/main --no-edit 2>&1 | head -10

    NEW_COMMIT=$(git rev-parse HEAD 2>/dev/null || echo "")

    echo ""

    if [ -n "$OLD_COMMIT" ] && [ -n "$NEW_COMMIT" ] && [ "$OLD_COMMIT" != "$NEW_COMMIT" ]; then
        echo "Changes in product content:"
        echo "----------------------------"

        for pdir in "${PRODUCT_DIRS[@]}"; do
            CHANGES=$(git diff --name-status "$OLD_COMMIT".."$NEW_COMMIT" -- "$pdir/" 2>/dev/null || echo "")
            if [ -n "$CHANGES" ]; then
                echo ""
                echo "$pdir/:"
                echo "$CHANGES" | while IFS=$'\t' read -r status file; do
                    case "$status" in
                        A) echo "  + NEW: $file" ;;
                        M) echo "  ~ UPDATED: $file" ;;
                        D) echo "  - REMOVED: $file" ;;
                        *) echo "  ? $status: $file" ;;
                    esac
                done
            fi
        done
    else
        echo "Already up to date — no changes pulled."
    fi
else
    # ---------------------------------------------------------------
    # Mode 2: Plugin cache — versioned directory layout
    # ---------------------------------------------------------------
    echo "Mode: plugin cache (not a git repo)"
    echo ""

    # Find the git source repo
    SOURCE_DIR=""

    if [ -f "$COUNSEL_DIR/.source-repo" ]; then
        CONFIGURED=$(cat "$COUNSEL_DIR/.source-repo" | tr -d '[:space:]')
        if [ -d "$CONFIGURED/.git" ] && [ -f "$CONFIGURED/VERSION" ]; then
            SOURCE_DIR="$CONFIGURED"
        fi
    fi

    if [ -z "$SOURCE_DIR" ]; then
        for candidate in \
            "$HOME/Desktop/counsel-os" \
            "$HOME/counsel-os" \
            "$HOME/dev/counsel-os" \
            "$HOME/src/counsel-os" \
            "$HOME/code/counsel-os" \
            "$HOME/projects/counsel-os"; do
            if [ -d "$candidate/.git" ] && [ -f "$candidate/VERSION" ]; then
                SOURCE_DIR="$candidate"
                break
            fi
        done
    fi

    if [ -z "$SOURCE_DIR" ]; then
        echo "ERROR: Cannot find counsel-os git repo to pull from."
        echo ""
        echo "The plugin cache at:"
        echo "  $COUNSEL_DIR"
        echo "is not a git repo, so we need the source repo to sync from."
        echo ""
        echo "To fix this, create a file at:"
        echo "  $COUNSEL_DIR/.source-repo"
        echo "containing the absolute path to your counsel-os git clone."
        echo ""
        echo "Example:"
        echo "  echo '\$HOME/Desktop/counsel-os' > '$COUNSEL_DIR/.source-repo'"
        exit 1
    fi

    echo "Source repo: $SOURCE_DIR"
    echo ""

    # Pull latest in the source repo
    echo "Pulling latest in source repo..."
    (cd "$SOURCE_DIR" && git fetch origin 2>&1 | head -5 && git merge origin/main --no-edit 2>&1 | head -10)
    echo ""

    # Read new version from source
    NEW_VERSION=$(cat "$SOURCE_DIR/VERSION" | tr -d '[:space:]')

    if [ -z "$NEW_VERSION" ]; then
        echo "ERROR: Could not read VERSION from source repo."
        exit 1
    fi

    VERSION_DIR="$COUNSEL_DIR/$NEW_VERSION"

    # ---------------------------------------------------------------
    # Sync into versioned directory
    # ---------------------------------------------------------------
    echo "Syncing to versioned directory: $NEW_VERSION/"
    echo ""

    mkdir -p "$VERSION_DIR"

    CHANGED_COUNT=0

    for pdir in "${PRODUCT_DIRS[@]}"; do
        if [ -d "$SOURCE_DIR/$pdir" ]; then
            mkdir -p "$VERSION_DIR/$pdir"
            rsync -a --delete "$SOURCE_DIR/$pdir/" "$VERSION_DIR/$pdir/" 2>/dev/null
            echo "  synced: $pdir/"
            CHANGED_COUNT=$((CHANGED_COUNT + 1))
        fi
    done

    for pfile in "${PRODUCT_FILES[@]}"; do
        if [ -f "$SOURCE_DIR/$pfile" ]; then
            mkdir -p "$VERSION_DIR/$(dirname "$pfile")"
            cp "$SOURCE_DIR/$pfile" "$VERSION_DIR/$pfile"
        fi
    done

    # Sync scripts directory
    if [ -d "$SOURCE_DIR/scripts" ]; then
        rsync -a --delete "$SOURCE_DIR/scripts/" "$VERSION_DIR/scripts/" 2>/dev/null
        echo "  synced: scripts/"
    fi

    # Sync docs directory
    if [ -d "$SOURCE_DIR/docs" ]; then
        rsync -a --delete "$SOURCE_DIR/docs/" "$VERSION_DIR/docs/" 2>/dev/null
        echo "  synced: docs/"
    fi

    # Sync browse directory
    if [ -d "$SOURCE_DIR/browse" ]; then
        rsync -a "$SOURCE_DIR/browse/" "$VERSION_DIR/browse/" 2>/dev/null
        echo "  synced: browse/"
    fi

    # Copy config.local.md if it exists in the previous version
    # (user-specific config that should carry forward)
    if [ -f "$COUNSEL_DIR/config.local.md" ] && [ ! -f "$VERSION_DIR/config.local.md" ]; then
        cp "$COUNSEL_DIR/config.local.md" "$VERSION_DIR/config.local.md"
        echo "  carried forward: config.local.md"
    fi

    # Install node_modules if package.json has dependencies
    if [ -f "$VERSION_DIR/package.json" ] && command -v bun &>/dev/null; then
        if grep -q '"dependencies"' "$VERSION_DIR/package.json"; then
            echo ""
            echo "Installing dependencies..."
            (cd "$VERSION_DIR" && bun install --frozen-lockfile 2>/dev/null || bun install 2>/dev/null) | tail -3
        fi
    fi

    echo ""
    echo "Synced $CHANGED_COUNT product directories + top-level files."

    # ---------------------------------------------------------------
    # Update installed_plugins.json
    # ---------------------------------------------------------------
    if [ -f "$INSTALLED_PLUGINS" ]; then
        echo ""
        echo "Updating installed_plugins.json..."

        # Use python3 (available on macOS) for reliable JSON editing
        python3 - "$INSTALLED_PLUGINS" "$PLUGIN_KEY" "$VERSION_DIR" "$NEW_VERSION" << 'PYEOF'
import json, sys
from datetime import datetime, timezone

plugins_file = sys.argv[1]
plugin_key = sys.argv[2]
new_path = sys.argv[3]
new_version = sys.argv[4]

with open(plugins_file, 'r') as f:
    data = json.load(f)

if plugin_key in data.get('plugins', {}):
    entries = data['plugins'][plugin_key]
    if entries:
        entries[0]['installPath'] = new_path
        entries[0]['version'] = new_version
        entries[0]['lastUpdated'] = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%S.000Z')
        with open(plugins_file, 'w') as f:
            json.dump(data, f, indent=2)
        print(f"  Updated: installPath -> {new_path}")
        print(f"  Updated: version -> {new_version}")
    else:
        print("  WARNING: Plugin entry is empty — cannot update.")
else:
    print(f"  WARNING: '{plugin_key}' not found in installed_plugins.json.")
    print("  Skills may not load. Re-install the plugin to fix.")
PYEOF
    else
        echo ""
        echo "WARNING: $INSTALLED_PLUGINS not found — cannot update install path."
        echo "Skills may not load until installed_plugins.json is fixed."
    fi

    # ---------------------------------------------------------------
    # Update root-level VERSION (for next run's OLD_VERSION)
    # ---------------------------------------------------------------
    echo "$NEW_VERSION" > "$COUNSEL_DIR/VERSION"

    # Self-update: copy the update script from source to root
    # (atomic move to avoid corrupting a running script)
    if [ -f "$SOURCE_DIR/update" ]; then
        cp "$SOURCE_DIR/update" "$COUNSEL_DIR/update.tmp"
        mv -f "$COUNSEL_DIR/update.tmp" "$COUNSEL_DIR/update"
        chmod +x "$COUNSEL_DIR/update"
    fi

    # Save source path for future updates
    echo "$SOURCE_DIR" > "$COUNSEL_DIR/.source-repo"

    # ---------------------------------------------------------------
    # Prune old versions (keep last N)
    # ---------------------------------------------------------------
    echo ""
    echo "Checking for old versions to prune..."

    # Find versioned directories (pattern: digits and dots)
    VERSIONS=()
    for d in "$COUNSEL_DIR"/*/; do
        dirname=$(basename "$d")
        if [[ "$dirname" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            VERSIONS+=("$dirname")
        fi
    done

    # Sort versions (lexicographic works for semver with consistent formatting)
    IFS=$'\n' SORTED=($(printf '%s\n' "${VERSIONS[@]}" | sort -V)); unset IFS

    if [ ${#SORTED[@]} -gt $KEEP_VERSIONS ]; then
        PRUNE_COUNT=$(( ${#SORTED[@]} - KEEP_VERSIONS ))
        echo "  Found ${#SORTED[@]} versions, keeping last $KEEP_VERSIONS."
        for ((i=0; i<PRUNE_COUNT; i++)); do
            OLD_DIR="$COUNSEL_DIR/${SORTED[$i]}"
            echo "  Pruning: ${SORTED[$i]}/"
            rm -rf "$OLD_DIR"
        done
    else
        echo "  ${#SORTED[@]} version(s) found — nothing to prune."
    fi
fi

echo ""

# -------------------------------------------------------------------
# Step 4: Show new version
# -------------------------------------------------------------------

NEW_VERSION="unknown"
if [ -f "$COUNSEL_DIR/VERSION" ]; then
    NEW_VERSION=$(cat "$COUNSEL_DIR/VERSION")
fi

if [ "$OLD_VERSION" != "$NEW_VERSION" ]; then
    echo "Version: $OLD_VERSION -> $NEW_VERSION"
else
    echo "Version: $NEW_VERSION (unchanged)"
fi

echo ""

# -------------------------------------------------------------------
# Step 5: Verify user content is untouched
# -------------------------------------------------------------------

echo "User content location:"
echo "----------------------"
echo "  User data lives in Obsidian vault (not in plugin cache)."
echo "  Product content updates do not affect user data."
echo ""
echo "Update complete. Restart Claude Code to pick up new skills."
echo ""
