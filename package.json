{
  "name": "counsel-os",
  "version": "0.8.9",
  "description": "Legal operating system for Claude — contract review, negotiation, and practice management",
  "scripts": {
    "build": "bun build --target=bun --compile -e electron -e 'chromium-bidi/*' browse/src/cli.ts --outfile browse/dist/browse",
    "content-version": "python3 scripts/bump_content_versions.py",
    "test": "bun test",
    "test:server": "bun test browse/src",
    "typecheck": "tsc --noEmit -p browse/tsconfig.json"
  },
  "dependencies": {
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
